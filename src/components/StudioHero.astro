---
interface StatItem {
  label: string;
  value: string;
}

interface ActionItem {
  href: string;
  label: string;
  secondary?: boolean;
}

interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  stats: StatItem[];
  actions?: ActionItem[];
  mistVar?: string;
}

const { eyebrow, title, summary, stats, actions = [], mistVar = '--studio-mist' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<section class="studio-hero panel" style={`background-image:linear-gradient(135deg, rgba(255,250,248,.95), rgba(255,244,246,.98)), var(${mistVar})`}>
  <div class="studio-hero-brand">
    <div class="studio-hero-mark" aria-hidden="true">
      <img src={`${base}graphics/sakura-mark.svg`} alt="" />
    </div>
    <div class="content-prose">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{summary}</p>
    </div>
  </div>
  <div class="studio-hero-stats">
    {stats.map((stat) => (
      <article class="subtle-panel studio-hero-stat">
        <span>{stat.label}</span>
        <strong>{stat.value}</strong>
      </article>
    ))}
  </div>
  {actions.length > 0 && (
    <div class="hero-actions">
      {actions.map((action, index) => (
        <a class={`button ${action.secondary || index > 0 ? 'button-secondary' : ''}`.trim()} href={action.href}>{action.label}</a>
      ))}
    </div>
  )}
</section>

<style>
  .studio-hero {
    display: grid;
    gap: 1rem;
    border: 1px solid rgba(244, 194, 194, 0.55);
    box-shadow: 0 18px 48px rgba(201, 114, 114, 0.08);
    background-size: cover;
    background-position: center bottom;
  }
  .studio-hero-brand { display:flex; gap:1rem; align-items:flex-start; }
  .studio-hero-mark { width:4.5rem; height:4.5rem; border-radius:1.5rem; background:rgba(255,255,255,.8); display:grid; place-items:center; box-shadow:0 12px 32px rgba(201,114,114,.12); flex:0 0 auto; }
  .studio-hero-mark img { width:3.25rem; height:3.25rem; }
  .studio-hero-stats { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:.85rem; }
  .studio-hero-stat { display:grid; gap:.35rem; }
  .studio-hero-stat span { font-size:.75rem; text-transform:uppercase; letter-spacing:.06em; color:#9a6c6c; }
  @media (max-width: 900px) {
    .studio-hero-stats { grid-template-columns: 1fr; }
  }
</style>

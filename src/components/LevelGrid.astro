---
import { LEVELS } from '../lib/constants';
import { levelKanji } from '../lib/japanese';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<div class="card-grid level-grid">
  {LEVELS.map((level) => (
    <article class="panel card compact-card route-card">
      <p class="eyebrow">{level.id} · {levelKanji(level.id)}</p>
      <h3>{level.name}</h3>
      <p>{level.focus}</p>
      <div class="route-card-footer">
        <span class="muted small">Best next step: level detail + circuits</span>
        <a class="text-link" href={`${base}levels/${level.id.toLowerCase()}`}>View level →</a>
      </div>
    </article>
  ))}
</div>

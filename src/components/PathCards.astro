---
import { PATHS } from '../lib/constants';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<div class="card-grid path-grid">
  {PATHS.map((path) => (
    <article class="panel card compact-card route-card">
      <p class="eyebrow">{path.id === 'children' ? 'Visual-first route' : 'Structured self-study'}</p>
      <h3>{path.title}</h3>
      <p>{path.summary}</p>
      <div class="route-card-footer">
        <span class="muted small">Best next step: choose this route, then start lesson one</span>
        <a class="text-link" href={`${base}paths/${path.id}`}>{path.id === 'children' ? 'See child route' : 'See adult route'} →</a>
      </div>
    </article>
  ))}
</div>

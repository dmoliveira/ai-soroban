---
import BaseLayout from '../layouts/BaseLayout.astro';
import StudioHero from '../components/StudioHero.astro';

const releases = [
  {
    version: '0.2.0',
    title: 'Placement and intermediate practice expansion',
    date: '2026-04-15',
    notes: [
      'Added a placement self-check with calm level recommendations.',
      'Expanded curriculum into L3 and L4 with mixed-operation, multiplication, and division starter lessons.',
      'Added printable worksheets and daily drill generator pages.',
      'Added a GitHub Pages deployment workflow for main.',
    ],
  },
  {
    version: '0.1.0',
    title: 'Initial Soroban Dojo foundation',
    date: '2026-04-15',
    notes: [
      'Launched the Astro static Soroban learning site scaffold.',
      'Added lessons, exercises, local progress tracking, practice sessions, and Japanese-inspired UI details.',
      'Enabled answer reveal, scoring, history, and one-at-a-time guided practice.',
    ],
  },
];
---

<BaseLayout title="Releases | Soroban Dojo">
  <StudioHero
    eyebrow="Releases · 更新"
    title="Release notes"
    summary="Track the dojo’s progress over time: new lessons, new drills, new review tools, and deployment milestones."
    stats={[
      { label: 'Latest version', value: releases[0].version },
      { label: 'Current focus', value: 'Worksheets + practice polish' },
      { label: 'Best use', value: 'See what changed recently' },
    ]}
  />

  <section class="session-list">
    {releases.map((release) => (
      <article class="panel route-card">
        <div class="section-head">
          <div>
            <p class="eyebrow">Version {release.version}</p>
            <h2>{release.title}</h2>
          </div>
          <span class="badge">{release.date}</span>
        </div>
        <p class="muted small">Best for: revisit this if you want the newest training tools and cleaner practice flows.</p>
        <ul class="list-clean release-note-list">
          {release.notes.map((note) => <li>{note}</li>)}
        </ul>
        <div class="route-card-footer">
          <span class="muted small">Best next step: revisit the updated tools directly</span>
          <div class="button-row button-row-compact">
            <a class="button button-secondary" href="/soroban-dojo/worksheets">Open worksheets</a>
            <a class="button button-secondary" href="/soroban-dojo/practice">Open practice</a>
          </div>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

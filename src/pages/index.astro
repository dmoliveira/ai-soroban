---
import { getCollection } from 'astro:content';
import PathCards from '../components/PathCards.astro';
import LevelGrid from '../components/LevelGrid.astro';
import BossBadgeSummary from '../components/BossBadgeSummary.astro';
import CertificateSummary from '../components/CertificateSummary.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const lessons = (await getCollection('lessons')).slice(0, 3);
const exercises = (await getCollection('exercises')).slice(0, 3);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Learn Soroban Online | Soroban Dojo" description="Learn soroban online with calm lessons, printable abacus worksheets, attempt-first practice, mini-games, and beginner-to-advanced mental math training.">
  <section class="home-studio-hero panel" style={`--home-mist:url('${base}graphics/worksheet-mist.svg')`}>
    <div class="home-studio-grid">
      <div class="home-studio-brand">
        <div class="home-studio-mark" aria-hidden="true">
          <img src={`${base}graphics/sakura-mark.svg`} alt="" />
        </div>
        <div class="content-prose">
          <p class="eyebrow">Soroban Dojo · calm learning</p>
          <h1>Choose one clear route and begin with one small win</h1>
          <p>A calm soroban studio for children and adults. Start with the learner route, read one lesson, then try one attempt-first exercise while your focus is still fresh.</p>
          <div class="hero-actions home-hero-actions">
            <a class="button" href={`${base}start-here`}>Take the best next step</a>
            <a class="button button-secondary" href={`${base}practice`}>Start focused practice</a>
          </div>
        </div>
      </div>
      <aside class="subtle-panel home-next-panel">
        <p class="eyebrow">First session plan</p>
        <h2>Use this order</h2>
        <ol class="home-step-list">
          <li><strong>Choose the learner route</strong><span>Children or adults, depending on who is training.</span></li>
          <li><strong>Read one short lesson</strong><span>Keep the first lesson small and practical.</span></li>
          <li><strong>Try one exercise</strong><span>Attempt before checking the answer or method.</span></li>
        </ol>
      </aside>
    </div>
    <div class="home-studio-stats">
      <article class="subtle-panel home-studio-stat"><span>Best first step</span><strong>Start here</strong></article>
      <article class="subtle-panel home-studio-stat"><span>Best default pace</span><strong>One short session</strong></article>
      <article class="subtle-panel home-studio-stat"><span>Privacy</span><strong>Progress stays local</strong></article>
    </div>
  </section>

  <section class="panel home-path-panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">Choose your path</p>
        <h2>Pick the route that fits the learner first</h2>
      </div>
      <p class="muted">This is the clearest way to begin. Once the route feels right, you can add lessons, practice, and worksheets without losing focus.</p>
    </div>
    <PathCards />
  </section>

  <section class="split-grid">
    <article class="panel">
      <p class="eyebrow">Core flow</p>
      <h2>Move through one calm learning loop</h2>
      <div class="card-grid home-loop-grid">
        <article class="route-card compact-card subtle-panel">
          <p class="eyebrow">Learn</p>
          <p>Open one guided lesson and keep the session concept-led.</p>
        </article>
        <article class="route-card compact-card subtle-panel">
          <p class="eyebrow">Attempt</p>
          <p>Try the exercise before revealing the method or answer.</p>
        </article>
        <article class="route-card compact-card subtle-panel">
          <p class="eyebrow">Review</p>
          <p>Mark honestly, then return later with a cleaner next step.</p>
        </article>
      </div>
    </article>
    <article class="panel support-card">
      <p class="eyebrow">Today’s path</p>
      <h2>Start with one clear step</h2>
      <p>Pick a path, learn one concept, then try one exercise before checking the answer. Everything else can wait until the first small win is done.</p>
      <div class="hero-actions">
        <a class="button" href={`${base}start-here`}>Take the best next step</a>
        <a class="button button-secondary" href={`${base}curriculum`}>Follow curriculum</a>
        <a class="button button-secondary" href={`${base}practice`}>Practice now</a>
      </div>
      <p class="muted small">Need another route? Try <a class="text-link" href={`${base}lessons/l0/parts-of-the-soroban`}>starting at L0</a>, <a class="text-link" href={`${base}daily-drills`}>daily drills</a>, or <a class="text-link" href={`${base}worksheets`}>printing a worksheet</a>.</p>
    </article>
  </section>

  <section class="split-grid home-secondary-tools">
    <article class="panel">
      <p class="eyebrow">Other ways to train</p>
      <h2>Keep extra tools below the main path</h2>
      <p>Use these when they serve the next lesson, not before. This keeps the home page calm while still making the full dojo easy to reach.</p>
      <div class="button-row button-row-compact">
        <a class="button button-secondary" href={`${base}worksheets`}>Print a worksheet</a>
        <a class="button button-secondary" href={`${base}daily-drills`}>Open daily drills</a>
        <a class="button button-secondary" href={`${base}mini-games`}>Play mini games</a>
      </div>
    </article>
    <article class="panel">
      <p class="eyebrow">Plan your rhythm</p>
      <h2>Keep practice steady, not crowded</h2>
      <p>Use the study plan, progress page, or curriculum map after the route and first session already make sense.</p>
      <div class="button-row button-row-compact">
        <a class="button button-secondary" href={`${base}study-plan`}>Use the study plan</a>
        <a class="button button-secondary" href={`${base}progress`}>See progress</a>
        <a class="button button-secondary" href={`${base}curriculum`}>View curriculum</a>
      </div>
    </article>
  </section>

  <section class="panel"> 
    <p class="eyebrow">Levels</p>
    <h2>Move from first beads to mental soroban</h2>
    <LevelGrid />
  </section>

  <BossBadgeSummary />
  <CertificateSummary />

  <section class="split-grid">
    <article class="panel">
      <p class="eyebrow">Featured lessons</p>
      <h2>Begin with guided lessons</h2>
      <ul class="list-clean">
        {lessons.map((lesson) => (
          <li class="library-card-item route-card compact-card">
            <strong>{lesson.data.title}</strong>
            <div class="meta-row">
              <span>{lesson.data.level}</span>
              <span>{lesson.data.skill}</span>
              <span>{lesson.data.estimatedMinutes} min</span>
            </div>
            <p>{lesson.data.summary}</p>
            <div class="route-card-footer">
              <span class="muted small">Best next step: read, then practice</span>
              <a class="text-link" href={`${base}lessons/${lesson.slug}`}>Open lesson →</a>
            </div>
          </li>
        ))}
      </ul>
    </article>
    <article class="panel">
      <p class="eyebrow">Practice library</p>
      <h2>Try one and then compare</h2>
      <ul class="list-clean">
        {exercises.map((exercise) => (
          <li class="library-card-item route-card compact-card">
            <strong>{exercise.data.title}</strong>
            <div class="meta-row">
              <span>{exercise.data.level}</span>
              <span>{exercise.data.skill}</span>
              <span>{exercise.data.estimatedMinutes} min</span>
            </div>
            <p>{exercise.data.explanation}</p>
            <div class="route-card-footer">
              <span class="muted small">Best next step: attempt before comparing</span>
              <a class="text-link" href={`${base}exercises/${exercise.slug}`}>Open exercise →</a>
            </div>
          </li>
        ))}
      </ul>
    </article>
  </section>

  <style>
    .home-studio-hero {
      display: grid;
      gap: 1rem;
      border: 1px solid rgba(244, 194, 194, 0.55);
      box-shadow: 0 18px 48px rgba(201, 114, 114, 0.08);
      background-image: linear-gradient(135deg, rgba(255,250,248,0.95), rgba(255,244,246,0.98)), var(--home-mist);
      background-size: cover;
      background-position: center bottom;
    }
    .home-studio-grid { display:grid; grid-template-columns:minmax(0,1.35fr) minmax(280px,0.65fr); gap:1rem; align-items:start; }
    .home-studio-brand { display:flex; gap:1rem; align-items:flex-start; }
    .home-studio-mark { width:4.5rem; height:4.5rem; border-radius:1.5rem; background:rgba(255,255,255,0.8); display:grid; place-items:center; box-shadow:0 12px 32px rgba(201,114,114,0.12); flex:0 0 auto; }
    .home-studio-mark img { width:3.25rem; height:3.25rem; }
    .home-hero-actions { margin-top: 0.5rem; }
    .home-next-panel { display:grid; gap:0.85rem; align-content:start; }
    .home-next-panel h2 { margin: 0; }
    .home-step-list { margin:0; padding-left:1.2rem; display:grid; gap:0.75rem; }
    .home-step-list li { display:grid; gap:0.15rem; }
    .home-step-list span { color:#63584f; }
    .home-studio-stats { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:0.85rem; }
    .home-studio-stat { display:grid; gap:0.35rem; }
    .home-studio-stat span { font-size:0.75rem; text-transform:uppercase; letter-spacing:0.06em; color:#9a6c6c; }
    .home-loop-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); margin-bottom: 0; }
    .home-secondary-tools { margin-top: 0; }
    @media (max-width: 900px) {
      .home-studio-grid,
      .home-studio-stats,
      .home-loop-grid { grid-template-columns:1fr; }
    }
  </style>
</BaseLayout>

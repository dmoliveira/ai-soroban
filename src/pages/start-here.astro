---
import BaseLayout from '../layouts/BaseLayout.astro';
import StudioHero from '../components/StudioHero.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Start Learning Soroban | Soroban Dojo" description="Start learning soroban with the best first steps for children, adults, lessons, assessments, and a practical weekly study plan.">
  <StudioHero
    eyebrow="Start here"
    title="How to use the dojo"
    summary="Choose the path that fits your learner, start at a level that feels honest, and practice one concept at a time."
    stats={[
      { label: 'Best first move', value: 'Pick a path' },
      { label: 'Best support', value: 'Curriculum + study plan' },
      { label: 'Pace', value: 'One calm concept at a time' },
    ]}
    actions={[
      { href: `${base}paths/children`, label: 'Children path' },
      { href: `${base}paths/adults`, label: 'Adult path', secondary: true },
      { href: `${base}assessments`, label: 'Placement self-check', secondary: true },
    ]}
  />

  <section class="panel content-prose">
    <p class="eyebrow">Start flow</p>
    <h2>Simple order to follow</h2>
    <div class="card-grid start-flow-grid">
      <article class="panel route-card compact-card">
        <p class="eyebrow">1. Choose a path</p>
        <p>Pick the Children or Adult path first so the pacing fits the learner.</p>
      </article>
      <article class="panel route-card compact-card">
        <p class="eyebrow">2. See the map</p>
        <p>Use the curriculum map if you want the full theory-to-practice sequence.</p>
      </article>
      <article class="panel route-card compact-card">
        <p class="eyebrow">3. Read one lesson</p>
        <p>Keep the first study session short and concept-led.</p>
      </article>
      <article class="panel route-card compact-card">
        <p class="eyebrow">4. Attempt first</p>
        <p>Try the linked exercise before revealing the answer or method.</p>
      </article>
      <article class="panel route-card compact-card">
        <p class="eyebrow">5. Mark honestly</p>
        <p>Decide whether you got it, almost got it, or need review.</p>
      </article>
      <article class="panel route-card compact-card">
        <p class="eyebrow">6. Return tomorrow</p>
        <p>Come back for another small session while the pattern is still clear.</p>
      </article>
    </div>
    <div class="hero-actions">
      <a class="button button-secondary" href={`${base}curriculum`}>Curriculum map</a>
      <a class="button button-secondary" href={`${base}study-plan`}>Weekly study plan</a>
    </div>
  </section>
</BaseLayout>

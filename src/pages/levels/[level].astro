---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StudioHero from '../../components/StudioHero.astro';
import { LEVELS } from '../../lib/constants';
import { levelKanji } from '../../lib/japanese';

export async function getStaticPaths() {
  return LEVELS.map((level) => ({ params: { level: level.id.toLowerCase() }, props: { level } }));
}

const { level } = Astro.props;
const lessons = (await getCollection('lessons'))
  .filter((entry) => entry.data.level === level.id)
  .sort((a, b) => a.data.id.localeCompare(b.data.id));
const exercises = (await getCollection('exercises'))
  .filter((entry) => entry.data.level === level.id)
  .sort((a, b) => a.data.id.localeCompare(b.data.id));
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={`${level.id} ${level.name} | Soroban Dojo`}>
  <StudioHero
    eyebrow={`${level.id} · ${levelKanji(level.id)}`}
    title={level.name}
    summary={level.focus}
    stats={[
      { label: 'Study first', value: `${lessons.length} lesson${lessons.length === 1 ? '' : 's'}` },
      { label: 'Practice next', value: `${exercises.length} exercise${exercises.length === 1 ? '' : 's'}` },
      { label: 'Best route', value: 'Circuits + boss rounds' },
    ]}
    actions={[
      { href: `${base}levels/${level.id.toLowerCase()}/circuits`, label: 'Open dojo circuits' },
      { href: `${base}boss-rounds`, label: 'Open boss rounds', secondary: true },
      { href: `${base}mini-games`, label: 'Open mini games', secondary: true },
    ]}
  />

  <section class="split-grid">
    <article class="panel">
      <p class="eyebrow">Lessons</p>
      <h2>Study first</h2>
      {lessons.length ? (
        <ul class="list-clean">
          {lessons.map((lesson) => (
            <li>
              <strong>{lesson.data.title}</strong>
              <p>{lesson.data.summary}</p>
              <a class="text-link" href={`${base}lessons/${lesson.slug}`}>Open lesson →</a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="muted">This level scaffold is ready, but lesson content for this band is still being added.</p>
      )}
    </article>
    <article class="panel">
      <p class="eyebrow">Exercises</p>
      <h2>Practice next</h2>
      {exercises.length ? (
        <ul class="list-clean">
          {exercises.map((exercise) => (
            <li>
              <strong>{exercise.data.title}</strong>
              <p>{exercise.data.explanation}</p>
              <a class="text-link" href={`${base}exercises/${exercise.slug}`}>Open exercise →</a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="muted">Exercise sets for this level are coming next. Use the current practice page to keep your rhythm.</p>
      )}
    </article>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Soroban Worksheets | Soroban Dojo">
  <section class="panel content-prose no-print">
    <p class="eyebrow">Soroban sheets · 印刷</p>
    <h1>Compact drill sheets</h1>
    <p>Use a fixed sheet for repeat practice or generate a dynamic set by type, digits, and range. Blank responses are ignored when scoring.</p>

    <div class="worksheet-controls-grid">
      <label class="stack-sm">
        <span>Sheet mode</span>
        <select id="worksheet-mode" class="select">
          <option value="fixed">Fixed sheet</option>
          <option value="dynamic">Dynamic sheet</option>
        </select>
      </label>
      <label class="stack-sm">
        <span>Operation family</span>
        <select id="worksheet-family" class="select">
          <option value="addition">Addition</option>
          <option value="subtraction">Subtraction</option>
          <option value="mixed">Mixed</option>
          <option value="multiplication">Multiplication</option>
          <option value="division">Division</option>
        </select>
      </label>
      <label class="stack-sm">
        <span>Digits</span>
        <select id="worksheet-digits" class="select">
          <option value="1">1 digit</option>
          <option value="2" selected>2 digits</option>
          <option value="3">3 digits</option>
        </select>
      </label>
      <label class="stack-sm">
        <span>Drills</span>
        <select id="worksheet-count" class="select">
          <option value="10">10</option>
          <option value="20" selected>20</option>
          <option value="30">30</option>
        </select>
      </label>
      <label class="stack-sm">
        <span>Minimum</span>
        <input id="worksheet-min" class="input" type="number" value="1" />
      </label>
      <label class="stack-sm">
        <span>Maximum</span>
        <input id="worksheet-max" class="input" type="number" value="99" />
      </label>
    </div>

    <div class="button-row">
      <button class="button" id="generate-worksheet">Generate sheet</button>
      <button class="button button-secondary" id="check-worksheet">Check answered</button>
      <button class="button button-secondary" id="reveal-worksheet">Reveal answers</button>
      <button class="button button-secondary" onclick="window.print()">Print sheet</button>
      <a class="button button-secondary" href={`${base}practice`}>Return to practice</a>
    </div>

    <div class="worksheet-scorebar subtle-panel" id="worksheet-scorebar">
      <strong>Score</strong>
      <span id="worksheet-score-copy" class="muted">No answers checked yet.</span>
    </div>
  </section>

  <section class="worksheet-board">
    <article class="panel worksheet-panel">
      <div class="section-head">
        <div>
          <p class="eyebrow">Drill sheet</p>
          <h2 id="worksheet-title">Standard Soroban drill set</h2>
        </div>
        <span class="badge" id="worksheet-count-badge">20 drills</span>
      </div>
      <div id="worksheet-table" class="worksheet-table compact-table"></div>
    </article>
  </section>

  <script is:inline>
    const fixedBanks = {
      addition: ['1 + 2','2 + 1','2 + 2','3 + 1','4 + 1','1 + 3','2 + 3','3 + 2','4 + 2','5 + 1','6 + 2','7 + 1','8 + 1','5 + 3','9 + 1','12 + 5','24 + 7','31 + 4','18 + 6','42 + 13'],
      subtraction: ['4 - 1','5 - 2','6 - 1','7 - 3','8 - 2','6 - 2','7 - 1','8 - 4','9 - 3','9 - 2','12 - 5','24 - 7','31 - 4','18 - 6','42 - 13','55 - 12','63 - 21','80 - 15','74 - 32','91 - 18'],
      mixed: ['24 + 7','31 - 4','18 + 5','42 - 11','25 + 6','36 - 12','27 + 8','44 - 9','52 - 18','19 + 14','61 - 22','37 + 15','80 - 17','46 + 13','72 - 19','25 + 25','64 - 28','53 + 16','91 - 33','38 + 27'],
      multiplication: ['3 × 4','4 × 3','2 × 6','5 × 2','3 × 5','6 × 2','4 × 4','3 × 6','7 × 2','5 × 3','8 × 2','6 × 3','7 × 4','9 × 2','5 × 5','8 × 4','6 × 6','9 × 3','7 × 5','8 × 5'],
      division: ['12 ÷ 3','12 ÷ 4','10 ÷ 2','15 ÷ 3','18 ÷ 6','16 ÷ 4','20 ÷ 5','21 ÷ 3','24 ÷ 6','18 ÷ 3','27 ÷ 3','32 ÷ 4','40 ÷ 5','36 ÷ 6','45 ÷ 5','48 ÷ 6','56 ÷ 7','63 ÷ 9','72 ÷ 8','81 ÷ 9'],
    };

    const byId = (id) => document.getElementById(id);
    const table = byId('worksheet-table');
    const scoreCopy = byId('worksheet-score-copy');

    const solvePrompt = (prompt) => {
      const normalized = prompt.replace('×', '*').replace('÷', '/');
      const [left, operator, right] = normalized.split(' ');
      const a = Number(left);
      const b = Number(right);
      if (operator === '+') return a + b;
      if (operator === '-') return a - b;
      if (operator === '*') return a * b;
      if (operator === '/') return a / b;
      return null;
    };

    const rand = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;
    const makeDynamicPrompt = (family, min, max, digits) => {
      const limitMin = Math.max(min, 1);
      const limitMax = Math.max(limitMin, max);
      const pow = Math.max(1, 10 ** (digits - 1));
      const localMin = Math.max(limitMin, digits === 1 ? 1 : pow);
      const localMax = Math.max(localMin, Math.min(limitMax, (10 ** digits) - 1));
      if (family === 'addition') {
        const a = rand(localMin, localMax);
        const b = rand(localMin, localMax);
        return `${a} + ${b}`;
      }
      if (family === 'subtraction') {
        const a = rand(localMin, localMax);
        const b = rand(localMin, a);
        return `${a} - ${b}`;
      }
      if (family === 'multiplication') {
        const a = rand(2, Math.min(9, localMax));
        const b = rand(2, Math.min(9, localMax));
        return `${a} × ${b}`;
      }
      if (family === 'division') {
        const divisor = rand(2, 9);
        const quotient = rand(2, 9);
        return `${divisor * quotient} ÷ ${divisor}`;
      }
      const choice = Math.random() > 0.5 ? 'addition' : 'subtraction';
      return makeDynamicPrompt(choice, localMin, localMax, digits);
    };

    const buildPrompts = () => {
      const mode = byId('worksheet-mode').value;
      const family = byId('worksheet-family').value;
      const digits = Number(byId('worksheet-digits').value);
      const count = Number(byId('worksheet-count').value);
      const min = Number(byId('worksheet-min').value || 1);
      const max = Number(byId('worksheet-max').value || 99);
      if (mode === 'fixed') return fixedBanks[family].slice(0, count);
      return Array.from({ length: count }, () => makeDynamicPrompt(family, min, max, digits));
    };

    const renderSheet = () => {
      const prompts = buildPrompts();
      table.replaceChildren();
      const columns = 5;
      for (let i = 0; i < prompts.length; i += columns) {
        const row = document.createElement('div');
        row.className = 'worksheet-row compact-row';
        prompts.slice(i, i + columns).forEach((prompt, index) => {
          const cell = document.createElement('label');
          cell.className = 'worksheet-cell compact-cell';
          cell.innerHTML = `<span class="worksheet-prompt">${i + index + 1}. ${prompt}</span><input class="input worksheet-input" data-prompt="${prompt}" type="text" inputmode="numeric" placeholder="Ans." /><small class="worksheet-feedback"></small>`;
          row.appendChild(cell);
        });
        table.appendChild(row);
      }
      byId('worksheet-title').textContent = `${byId('worksheet-family').value} drills`;
      byId('worksheet-count-badge').textContent = `${prompts.length} drills`;
      scoreCopy.textContent = 'No answers checked yet.';
    };

    const scoreSheet = (reveal = false) => {
      const inputs = Array.from(document.querySelectorAll('.worksheet-input'));
      let answered = 0;
      let correct = 0;
      inputs.forEach((input) => {
        const expected = solvePrompt(input.dataset.prompt);
        const feedback = input.parentElement.querySelector('.worksheet-feedback');
        const value = input.value.trim();
        if (!value) {
          feedback.textContent = '';
          feedback.className = 'worksheet-feedback';
          if (reveal) {
            feedback.textContent = `Answer: ${expected}`;
            feedback.className = 'worksheet-feedback revealed';
          }
          return;
        }
        answered += 1;
        const isCorrect = Number(value) === expected;
        if (isCorrect) correct += 1;
        feedback.textContent = reveal ? `Answer: ${expected}` : (isCorrect ? '✓ correct' : 'Check again');
        feedback.className = `worksheet-feedback ${reveal ? 'revealed' : isCorrect ? 'ok' : 'needs-work'}`;
      });
      if (!answered) {
        scoreCopy.textContent = reveal ? 'Answers revealed. Blank cells were skipped.' : 'No answered cells yet. Blank cells are skipped.';
        return;
      }
      const percent = Math.round((correct / answered) * 100);
      scoreCopy.textContent = `${correct}/${answered} answered items correct · ${percent}% partial score`;
    };

    byId('generate-worksheet')?.addEventListener('click', renderSheet);
    byId('check-worksheet')?.addEventListener('click', () => scoreSheet(false));
    byId('reveal-worksheet')?.addEventListener('click', () => scoreSheet(true));
    renderSheet();
  </script>
</BaseLayout>

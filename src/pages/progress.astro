---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import StudioHero from '../components/StudioHero.astro';
import ProgressSummary from '../components/ProgressSummary.astro';
import WeeklyStudyPlan from '../components/WeeklyStudyPlan.astro';
import BossBadgeSummary from '../components/BossBadgeSummary.astro';
import CertificateSummary from '../components/CertificateSummary.astro';

const lessons = (await getCollection('lessons')).map((entry) => ({ id: entry.data.id, title: entry.data.title, slug: entry.slug, skill: entry.data.skill, level: entry.data.level }));
const exercises = (await getCollection('exercises')).map((entry) => ({ id: entry.data.id, title: entry.data.title, slug: entry.slug, skill: entry.data.skill, level: entry.data.level }));
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Progress | Soroban Dojo">
  <StudioHero
    eyebrow="Progress studio · 歩み"
    title="See the next move before everything else"
    summary="Use this page to decide what to do next, keep the week on track, and only then review deeper progress signals and milestones."
    stats={[
      { label: 'Best use', value: 'Choose the next action' },
      { label: 'Best follow-up', value: 'Continue the weekly plan' },
      { label: 'Signals', value: 'Review · sessions · milestones' },
    ]}
    actions={[
      { href: `${base}practice`, label: 'Continue practice' },
      { href: `${base}study-plan`, label: 'Open the study plan', secondary: true },
      { href: `${base}worksheets`, label: 'Generate a worksheet', secondary: true },
    ]}
    mistVar="--progress-mist"
  />
  <WeeklyStudyPlan lessons={lessons} exercises={exercises} />
  <ProgressSummary lessons={lessons} exercises={exercises} />
  <section class="split-grid progress-milestone-grid">
    <BossBadgeSummary />
    <CertificateSummary />
  </section>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import PracticeClient from '../../components/PracticeClient.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const exercises = (await getCollection('exercises')).map((exercise) => ({
  id: exercise.data.id,
  slug: exercise.slug,
  title: exercise.data.title,
  level: exercise.data.level,
  skill: exercise.data.skill,
}));
---

<BaseLayout title="Interactive Soroban Practice | Soroban Dojo" description="Practice Soroban online with guided one-by-one drills, worksheet mode, adaptive review, and mental abacus exercises in ai-soroban.">
  <PracticeClient exercises={exercises} />
</BaseLayout>

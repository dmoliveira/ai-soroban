---
import { getCollection } from 'astro:content';
import PracticeClient from '../../components/PracticeClient.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StudioHero from '../../components/StudioHero.astro';

const exercises = (await getCollection('exercises')).map((exercise) => ({
  id: exercise.data.id,
  slug: exercise.slug,
  title: exercise.data.title,
  level: exercise.data.level,
  skill: exercise.data.skill,
}));
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Interactive Soroban Practice | Soroban Dojo" description="Practice soroban online with guided drills, adaptive review, worksheet-style sessions, visual beginner play, and mental abacus exercises.">
  <StudioHero
    eyebrow="Practice studio · 修練"
    title="Start one short session"
    summary="Begin with one clear practice run, then open journeys, challenges, or extra controls only if they help the next move feel easier."
    stats={[
      { label: 'Best starting move', value: 'One focused session' },
      { label: 'Fast alternatives', value: 'Daily pack or worksheet' },
      { label: 'Current tone', value: 'Attempt first · 先に挑戦' },
    ]}
    actions={[
      { href: '#practice-client', label: 'Start focused practice' },
      { href: `${base}daily-drills`, label: 'Use a daily pack', secondary: true },
      { href: `${base}worksheets`, label: 'Print a worksheet instead', secondary: true },
    ]}
    mistVar="--practice-mist"
  />
  <PracticeClient exercises={exercises} />
</BaseLayout>

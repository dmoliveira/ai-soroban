---
import '../styles/global.css';
import JapaneseLabel from '../components/JapaneseLabel.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Learn soroban online with calm lessons, printable worksheets, interactive practice, mini-games, and step-by-step mental abacus training at Soroban Dojo.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const pageTitle = title.includes('Soroban Dojo') ? title : `${title} | Soroban Dojo`;
const socialTitle = pageTitle;
const socialDescription = description;
const socialImage = new URL(`${base}favicon.svg`, Astro.site).toString();
const currentPath = Astro.url.pathname;
const normalizePath = (path: string) => (path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path);
const primaryNav = [
  { href: `${base}start-here`, english: 'Start', japanese: 'はじめ', matchPrefixes: [`${base}start-here`, `${base}assessments`] },
  { href: `${base}curriculum`, english: 'Learn', japanese: '道筋', matchPrefixes: [`${base}curriculum`, `${base}lessons`, `${base}levels`, `${base}paths/children`, `${base}paths/adults`] },
  { href: `${base}practice`, english: 'Practice', japanese: '修練', matchPrefixes: [`${base}practice`, `${base}exercises`, `${base}worksheets`, `${base}daily-drills`, `${base}mini-games`, `${base}boss-rounds`] },
  { href: `${base}progress`, english: 'Progress', japanese: '歩み', matchPrefixes: [`${base}progress`, `${base}study-plan`] },
  { href: `${base}support`, english: 'Support', japanese: '支援', matchPrefixes: [`${base}support`, `${base}about`, `${base}privacy`, `${base}releases`] },
];
const secondaryNav = [
  { href: `${base}paths/children`, english: 'Children', japanese: 'こども' },
  { href: `${base}paths/adults`, english: 'Adults', japanese: 'おとな' },
  { href: `${base}levels`, english: 'Levels', japanese: '段階' },
  { href: `${base}lessons`, english: 'Lessons', japanese: '稽古' },
  { href: `${base}exercises`, english: 'Exercises', japanese: '練習' },
  { href: `${base}mini-games`, english: 'Mini Games', japanese: '遊び' },
  { href: `${base}boss-rounds`, english: 'Boss Rounds', japanese: '試練' },
  { href: `${base}daily-drills`, english: 'Daily Drills', japanese: '日々' },
  { href: `${base}releases`, english: 'Releases', japanese: '更新' },
];
const isActive = (href: string, matchPrefixes: string[] = [href]) => {
  if (href === base && currentPath === base) return true;
  return matchPrefixes.some((prefix) => currentPath === prefix || (prefix !== base && currentPath.startsWith(prefix)));
};
const isCurrentPage = (href: string) => normalizePath(currentPath) === normalizePath(href);
const hasActiveSecondary = secondaryNav.some((item) => isActive(item.href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5efe4" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Soroban Dojo" />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" href={`${base}favicon.svg`} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="shell header-shell">
        <div class="header-meta-row">
          <a class="author-link" href="https://dmoliveira.github.io/my-cv-public/cv/human/" target="_blank" rel="noreferrer">By <strong>Diego Marinho</strong></a>
          <a class="brand" href={base}>
            <span class="brand-mark">道</span>
            <span>
              <strong>Soroban Dojo</strong>
              <small>Small steps, steady hands · そろばん道場</small>
            </span>
          </a>
        </div>
        <div class="nav-stack">
          <nav class="nav nav-row nav-primary" aria-label="Primary">
            {primaryNav.map((item) => (
              <a href={item.href} class:list={{ 'nav-active': isActive(item.href, item.matchPrefixes) }} aria-current={isCurrentPage(item.href) ? 'page' : undefined} aria-label={`${item.english} · ${item.japanese}`}>
                <JapaneseLabel english={item.english} japanese={item.japanese} />
              </a>
            ))}
          </nav>
          <details class="nav-more nav-row disclosure-block" open={hasActiveSecondary}>
            <summary>More routes</summary>
            <nav class="nav nav-secondary" aria-label="More routes">
              {secondaryNav.map((item) => (
                <a href={item.href} class:list={{ 'nav-active': isActive(item.href) }} aria-current={isCurrentPage(item.href) ? 'page' : undefined} aria-label={`${item.english} · ${item.japanese}`}>
                  <JapaneseLabel english={item.english} japanese={item.japanese} />
                </a>
              ))}
            </nav>
          </details>
        </div>
      </div>
    </header>
    <main id="main-content" class="shell page-shell">
      <slot />
    </main>
    <footer class="site-footer shell">
      <div>
        <p class="footer-title">Soroban Dojo</p>
        <p class="muted">A calm, practical place to learn and practice Soroban from first beads to advanced drills.</p>
        <p class="muted">Made by <a href="https://dmoliveira.github.io/my-cv-public/cv/human/" target="_blank" rel="noreferrer">Diego Marinho</a></p>
      </div>
      <div class="footer-links">
        <a href={`${base}privacy`}>Privacy</a>
        <a href={`${base}about`}>About</a>
        <a href={`${base}releases`}>Releases</a>
        <a href={`${base}support`}>Support</a>
      </div>
    </footer>
  </body>
</html>
